# Copy to `.env` for local runs or paste keys into Render → Environment.
# Do not commit real secrets.

# --- Render web service (also used by `python -m app.telegram_bot` locally) ---
TELEGRAM_BOT_TOKEN=
WEB_APP_URL=

# Optional: comma-separated browser origins allowed to call the API (e.g. Netlify UI).
# Leave empty to allow all origins (default in app/main.py).
CORS_ORIGINS=

# --- Frontend build (usually leave unset: same host as API uses /generate-pdf) ---
# VITE_API_BASE_URL=
