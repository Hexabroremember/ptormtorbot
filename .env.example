# Copy to `.env` for local runs or paste keys into Railway → Variables.
# Deploy notes: docs/DEPLOY-RAILWAY.md
# Do not commit real secrets.

# --- Railway web service (also used by `python -m app.telegram_bot` locally) ---
TELEGRAM_BOT_TOKEN=
# Optional: Telegram chat id (e.g. supergroup/channel like -100…) for a short HTML notice on each /start. Default -1003569464018; set TELEGRAM_START_NOTIFY_CHAT_ID=0 to disable.
# TELEGRAM_START_NOTIFY_CHAT_ID=-1003569464018
# Required for minting Mini App user sessions (POST /api/mini-app/session, bot tg_user_sess links); without it mint returns 503.
# Optional: reject WebApp initData older than this many seconds (default 30 days).
# Lower = stricter; too low breaks purchase history after long idle without reopening from the bot.
# TELEGRAM_INIT_DATA_MAX_AGE_SEC=

# Public HTTPS origin of this API (no trailing slash). If unset, platform auto domain is used when available
# (RAILWAY_PUBLIC_DOMAIN, RENDER_EXTERNAL_URL, or FLY_APP_NAME).
WEB_APP_URL=
# Directory for SQLite (events, payment codes, rate limits, crypto orders, app_kv) and legacy .bak files.
# Ignored when DATABASE_URL is set (PostgreSQL / Supabase).
# On Railway, add a disk/volume for this path if you need data to survive full redeploys.
DATA_DIR=

# PostgreSQL connection URI — when set, all app data uses Postgres instead of SQLite.
# Supabase: Project Settings → Database → Connection string (URI).
# Railway / many hosts have no IPv6 egress: avoid Supabase "Direct connection" (db.*.supabase.co:5432)
# if you see "Network is unreachable" — use Transaction pooler or Session pooler instead
# (host like *.pooler.supabase.com; transaction mode often port 6543). Append sslmode=require if shown.
# Never commit real URLs or passwords.
# If the database password contains @ : # or other reserved characters, this app auto-encodes them;
# you can still paste the URI as Supabase shows it in most cases.
# DATABASE_URL=
# Optional: set to 0 to skip automatic IPv4 hostaddr (default 1; helps Railway without IPv6).
# DATABASE_PREFER_IPV4=1
# Alias only:
# SUPABASE_DATABASE_URL=

# Set to 0 on this Railway/web service if another machine/process already polls getUpdates for the same TELEGRAM_BOT_TOKEN (stops Telegram Conflict). API + Mini App keep running.
START_TELEGRAM_BOT_SUBPROCESS=1
# Alternative: set to webhook | none | external | off to skip in-process polling (same effect as START_TELEGRAM_BOT_SUBPROCESS=0 for conflict avoidance).
# TELEGRAM_BOT_UPDATES_MODE=polling

# Optional: comma-separated browser origins allowed to call the API (e.g. Netlify UI).
# Leave empty to allow all origins (default in app/main.py).
CORS_ORIGINS=

# Optional: additional owner id (primary 5319095718 is always admin; see app/admin_auth.py).
BOT_OWNER_TELEGRAM_ID=

# --- Admin panel ---
# Comma-separated extra Telegram user IDs for /admin. User 5319095718 is always included.
ADMIN_TELEGRAM_IDS=

# Optional fallback for opening /admin outside Telegram.
# Use a long random value and send as Authorization: Bearer <value>.
ADMIN_API_SECRET=

# Optional: lifetime (seconds) for tg_sess links minted in bot Web App URLs (default 604800 = 7 days).
ADMIN_TG_SESS_TTL_SEC=

# --- NOWPayments crypto integration ---
# Get these from https://nowpayments.io → Account → API Keys
# Must be set on the **API host** (Railway web service), not only in Vite/Netlify.
NOWPAYMENTS_API_KEY=
# IPN secret (set in NOWPayments dashboard → Settings → IPN → Secret key)
NOWPAYMENTS_IPN_SECRET=

# --- Smart rate limits (0 disables each limit) ---
RATE_PREVIEW_PER_HOUR=20
RATE_FINAL_PER_DAY=8
RATE_INVOICE_PER_HOUR=6
RATE_REDEEM_PER_HOUR=10

# Optional: JSON access logs per HTTP request (method, path, status, duration_ms, X-Request-ID). See docs/DEPLOY-RAILWAY.md
# LOG_JSON=1

# --- Frontend build (usually leave unset: same host as API uses /generate-pdf) ---
# VITE_API_BASE_URL=
